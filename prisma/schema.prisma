// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- TABEL KATEGORI (SUDAH DIKUNCI PER CABANG) ---
model Category {
  id            Int      @id @default(autoincrement())
  category_name String
  owner_dept    String
  branch        String?  // 🔥 PASTIKAN BARIS INI ADA BRAY
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  assets        Asset[]
}

// --- TABEL ASET UTAMA ---
model Asset {
  id                Int          @id @default(autoincrement())
  asset_code        String       @unique // Kode otomatis (misal: IT-LAP-001)
  asset_name        String
  branch            String?      @default("HO - Head Office") 
  
  // Relasi Kategori
  category_id       Int
  category          Category     @relation(fields: [category_id], references: [id])
  
  // Detail Fisik & Lokasi
  serial_number     String?      // Bisa kosong kalau furnitur
  condition         String       @default("New") // New, Good, Fair, Damaged
  location          String?      
  managing_division String       // IT, GA, HR
  description       String?      @db.Text
  
  // Media & Dokumen (Simpan path/URL filenya)
  asset_image       String?      
  invoice_file      String?      

  // Finansial & Vendor
  price             Decimal      @db.Decimal(15, 2) // Support angka milyaran
  vendor_name       String?      
  purchase_date     DateTime
  warranty_date     DateTime?  

  // Status Lifecycle
  status            String       @default("Available") // Available, Assigned, Maintenance, Damaged
  
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  // Relasi ke tabel Peminjaman
  assignments       Assignment[]
}

// --- TABEL PEMINJAMAN (LOG AKTIVITAS) ---
model Assignment {
  id            Int       @id @default(autoincrement())
  
  asset_id      Int
  asset         Asset     @relation(fields: [asset_id], references: [id])
  
  borrower_name String
  department    String
  
  assign_date   DateTime  @default(now())
  return_date   DateTime?
  status        String    @default("Active") // Active, Returned
  notes         String?   @db.Text
}

// --- TABEL USER LOGIN ---
model User {
  id         Int      @id @default(autoincrement())
  name       String
  username   String   @unique  
  password   String
  role       String   @default("STAFF")
  branch     String   @default("ALL") 
  
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// --- TABEL LOG AUDIT ---
model Log {
  id        Int      @id @default(autoincrement())
  action    String   // Contoh: "CREATE", "UPDATE", "DELETE"
  entity    String   // Contoh: "ASSET", "USER", "ASSIGNMENT"
  detail    String   @db.Text
  user      String   // Nama user yang melakukan aksi
  role      String   // Role user tersebut
  createdAt DateTime @default(now())
}