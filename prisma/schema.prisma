// --- KONFIGURASI DATABASE ---
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- TABEL 1: Category ---
model Category {
  id            Int      @id @default(autoincrement())
  category_name String
  owner_dept    String   // Berisi "IT" atau "GA"
  created_at    DateTime @default(now())
  
  assets        Asset[]
}

// --- TABEL 2: Asset ---
model Asset {
  id              Int      @id @default(autoincrement())
  asset_code      String   @unique
  name            String
  category_id     Int
  
  status          String   @default("Available")
  purchase_date   DateTime
  
  specification   String?  @db.Text
  purchase_price  Float?
  vendor_name     String?
  warranty_expiry DateTime?

  branch          String   @default("HQ")

  created_at      DateTime @default(now())
  
  category        Category     @relation(fields: [category_id], references: [id])
  assignments     Assignment[] 
}

// --- TABEL 3: Assignment ---
model Assignment {
  id            Int       @id @default(autoincrement())
  asset_id      Int
  borrower_name String
  department    String
  assign_date   DateTime  @default(now())
  return_date   DateTime?
  notes         String?

  asset         Asset     @relation(fields: [asset_id], references: [id])
}

// --- TABEL 4: User (Untuk Login) ---
model User {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  password   String   // Password dienkripsi (hashed)
  name       String
  role       String   @default("user") // superadmin, admin, user
  branch     String   @default("HQ") // Lokasi cabang user ini bertugas
  created_at DateTime @default(now())
}